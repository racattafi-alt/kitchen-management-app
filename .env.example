# =============================================================================
# Kitchen Management App — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Database (required) ---
DATABASE_URL=mysql://user:password@localhost:3306/kitchen_management

# --- Session secret (required) ---
# Any random string of at least 32 characters.
JWT_SECRET=change-me-to-a-random-32-char-secret

# =============================================================================
# Auth mode: choose "local" or "manus"
# =============================================================================

# AUTH_PROVIDER controls the server-side auth strategy.
# VITE_AUTH_PROVIDER controls the client-side login redirect.
# Both must match.

# --- Option A: Local auth (email + password, no external dependencies) ---
AUTH_PROVIDER=local
VITE_AUTH_PROVIDER=local

# --- Option B: Manus OAuth (default, requires Manus platform) ---
# AUTH_PROVIDER=manus
# VITE_AUTH_PROVIDER=manus
# VITE_APP_ID=your-manus-app-id
# OAUTH_SERVER_URL=https://oauth.manus.computer
# VITE_OAUTH_PORTAL_URL=https://portal.manus.computer
# OWNER_OPEN_ID=your-manus-openid   # This user gets admin role automatically

# =============================================================================
# Optional: AI assistant / forge features
# =============================================================================
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# =============================================================================
# Server
# =============================================================================
# PORT=3000
# NODE_ENV=production
